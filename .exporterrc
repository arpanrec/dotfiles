export LANG=en_US.UTF-8
export LC_CTYPE="en_US.UTF8"
export LC_NUMERIC="en_US.UTF8"
export LC_TIME="en_US.UTF8"
export LC_COLLATE="en_US.UTF8"
export LC_MONETARY="en_US.UTF8"
export LC_MESSAGES="en_US.UTF8"
export LC_PAPER="en_US.UTF8"
export LC_NAME="en_US.UTF8"
export LC_ADDRESS="en_US.UTF8"
export LC_TELEPHONE="en_US.UTF8"
export LC_MEASUREMENT="en_US.UTF8"
export LC_IDENTIFICATION="en_US.UTF8"
export LC_ALL=en_US.UTF8

LD_LIBRARY_PATH=$HOME/.local/lib64:$HOME/.local/lib:$LD_LIBRARY_PATH
export LD_LIBRARY_PATH

if ! [[ "$PATH" =~ /usr/local/bin: ]]; then
    PATH="/usr/local/bin:$PATH"
    export PATH
fi

if ! [[ "$PATH" =~ /usr/local/sbin: ]]; then
    PATH="/usr/local/sbin:$PATH"
    export PATH
fi

if ! [[ "$PATH" =~ /sbin: ]]; then
    PATH="/sbin:$PATH"
    export PATH
fi

if ! [[ "$PATH" =~ /usr/sbin: ]]; then
    PATH="/usr/sbin:$PATH"
    export PATH
fi

# shellcheck source=/dev/null
if [ -f "$HOME/.secrets" ]; then
    source "$HOME/.secrets"
fi

for secret_file in ~/.secrets.d/*.sh; do
    ## Pickup any file ends with .sh
    # shellcheck source=/dev/null
    chmod +x "${secret_file}"
    # shellcheck source=/dev/null
    source "${secret_file}"
done

if [[ -d "/var/lib/snapd/snap/bin" ]] && [[ ! "$PATH" =~ /var/lib/snapd/snap/bin: ]]; then
    PATH="/var/lib/snapd/snap/bin:$PATH"
    export PATH
fi

if [[ -d "$HOME/.local/share/JetBrains/Toolbox/scripts" ]] && [[ ! "$PATH" =~ $HOME/.local/share/JetBrains/Toolbox/scripts: ]]; then
    PATH="$HOME/.local/share/JetBrains/Toolbox/scripts:$PATH"
    export PATH
fi

if [ -f "$HOME/.local/share/go/bin/go" ] && [[ ! "$PATH" =~ $HOME/.local/share/go/bin: ]]; then
    PATH="$HOME/.local/share/go/bin:$PATH"
    export PATH
fi

export GOPATH="$HOME/go"

if [[ ! "$PATH" =~ $HOME/go/bin: ]]; then
    PATH="$HOME/go/bin:$PATH"
    export PATH
fi

if [ -f "$HOME/.local/share/node/bin/node" ] && [[ ! "$PATH" =~ $HOME/.local/share/node/bin: ]]; then
    PATH="$HOME/.local/share/node/bin:$PATH"
    export PATH
fi

if [ -f "$HOME/.jdk.env.sh" ]; then
    # shellcheck source=/dev/null
    source "${HOME}/.jdk.env.sh"
fi

if [[ -f "$HOME/.local/share/coursier/bin/cs" ]] && [[ ! "$PATH" =~ $HOME/.local/share/coursier/bin: ]]; then
    PATH="$HOME/.local/share/coursier/bin:$PATH"
    export PATH
fi

if ! [[ "$PATH" =~ $HOME/.local/bin:$HOME/bin: ]]; then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
    export PATH
fi

if [[ -f "$HOME/.cargo/bin/cargo" ]] && [[ ! "$PATH" =~ $HOME/.cargo/bin: ]]; then
    PATH="$HOME/.cargo/bin:$PATH"
    # shellcheck source=/dev/null
    source "$HOME/.cargo/env"
    export PATH
fi

export GPG_TTY=$(tty)

# Not working on centos7 systems
# gpg-connect-agent updatestartuptty /bye >/dev/null

if hash vim &>/dev/null; then
    export EDITOR=vim
fi

if [[ -f "/usr/bin/ksshaskpass" ]]; then
    SSH_ASKPASS="/usr/bin/ksshaskpass"
    export SSH_ASKPASS
    SH_ASKPASS_REQUIRE=prefer
    export SH_ASKPASS_REQUIRE
    GIT_ASKPASS="/usr/bin/ksshaskpass"
    export GIT_ASKPASS
fi
